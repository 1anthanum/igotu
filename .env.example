# IGOTU Environment Configuration
# Copy this to .env and update values for your environment

# Database (SQLite)
DB_PATH=./igotu.db

# JWT — MUST change in production
JWT_SECRET=your-very-long-random-secret-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Anthropic (Claude API) — Required for AI chat companion
# Leave empty to disable AI chat; all other features work without it
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# Frontend
VITE_API_URL=/api
