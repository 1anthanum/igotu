# IGOTU Environment Configuration
# Copy this to .env and update values for your environment

# Database (SQLite)
DB_PATH=./igotu.db

# JWT — MUST change in production
JWT_SECRET=your-very-long-random-secret-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Mode A: shared deployment via alpha-proxy ───
# When PROXY_URL is set, ChatService routes through it instead of calling Anthropic directly.
# The proxy injects the real Anthropic key — keep ANTHROPIC_API_KEY blank in this mode.
PROXY_URL=
PROXY_PASSWORD=

# Friend-facing access password (Express middleware checks cookie + this value).
# Leave blank for local dev to skip the gate entirely.
ACCESS_PASSWORD=

# ─── Mode B: direct Anthropic key (local dev / personal hosting) ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# Frontend
VITE_API_URL=/api
